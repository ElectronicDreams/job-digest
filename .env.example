# Adzuna API credentials
# Register at https://developer.adzuna.com to get your app_id and app_key
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# LLM provider API key for onboarding
# Default provider is Google Gemini Flash (free tier)
# Get a free key at https://aisketch.google.com/gemini
# See config.example.json and README for alternative providers
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub PAT for Claude bot (used by Claude Code to push branches and open PRs)
# Generate a fine-grained token under Claude's GitHub account
# Required permissions: Contents, Issues, Pull requests, Metadata, Workflows
GITHUB_TOKEN=your_claude_github_pat_here